{
  "functions": {
    "api/*.js": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "routes": [

    {
      "src": "/api/live_status",
      "dest": "/api/live_status.js"
    },
    {
      "src": "/api/save_schedule",
      "dest": "/api/save_schedule.js"
    },
    {
      "src": "/api/schedules",
      "dest": "/api/schedules.js"
    },
    {
      "src": "/api/daily_works",
      "dest": "/api/daily_works.js"
    },
    {
      "src": "/api/save_daily_work",
      "dest": "/api/save_daily_work.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
